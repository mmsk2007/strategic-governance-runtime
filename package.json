{
  "name": "strategic-governance-runtime",
  "version": "2.0.0",
  "description": "Strategic Governance Runtime - A framework for governing autonomous AI agent decisions with authority, delegation, and deterministic replay",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "governance",
    "ai",
    "autonomous-agents",
    "authority",
    "delegation",
    "audit",
    "compliance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmsk2007/strategic-governance-runtime.git"
  }
}
